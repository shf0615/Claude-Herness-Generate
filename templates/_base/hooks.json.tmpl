{
  "{{HOOKS_TIER}}": {
    "minimal": {
      "hooks": {}
    },
    "standard": {
      "hooks": {
        "PreToolUse": [
          {
            "matcher": "Bash",
            "hooks": [
              {
                "type": "command",
                "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '(rm\\s+-rf\\s+/|sudo\\s+|chmod\\s+777|:\\(\\)\\{|fork\\s+bomb|>\\s*/dev/sda|mkfs\\.)' && echo 'BLOCKED: Dangerous command detected' && exit 2 || exit 0",
                "timeout": 5
              }
            ],
            "description": "阻止危险的 Bash 命令（rm -rf /、sudo、chmod 777、fork bomb 等）",
            "id": "pre:bash:block-dangerous"
          }
        ],
        "PostToolUse": [],
        "Stop": [
          {
            "matcher": "*",
            "hooks": [
              {
                "type": "command",
                "command": "{{BUILD_CMD}} 2>&1 | tail -5 || echo 'WARNING: 构建检查失败'",
                "timeout": 60
              }
            ],
            "description": "会话结束时验证项目仍可构建",
            "id": "stop:build-check"
          }
        ]
      }
    },
    "strict": {
      "hooks": {
        "PreToolUse": [
          {
            "matcher": "Bash",
            "hooks": [
              {
                "type": "command",
                "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '(rm\\s+-rf\\s+/|sudo\\s+|chmod\\s+777|:\\(\\)\\{|--no-verify|--force)' && echo 'BLOCKED: Dangerous or bypass command detected' && exit 2 || exit 0",
                "timeout": 5
              }
            ],
            "description": "阻止危险命令和 hook 绕过标志（--no-verify、--force）",
            "id": "pre:bash:block-dangerous-strict"
          }
        ],
        "PostToolUse": [
          {
            "matcher": "Write|Edit",
            "hooks": [
              {
                "type": "command",
                "command": "{{FORMAT_CMD}} \"$CLAUDE_FILE_PATH\" 2>/dev/null; {{LINT_CMD}} \"$CLAUDE_FILE_PATH\" 2>&1 | head -20 || true",
                "timeout": 30
              }
            ],
            "description": "写入或编辑文件后自动格式化并运行 lint 检查",
            "id": "post:write:auto-lint"
          }
        ],
        "Stop": [
          {
            "matcher": "*",
            "hooks": [
              {
                "type": "command",
                "command": "{{BUILD_CMD}} 2>&1 | tail -5 && {{TEST_CMD}} 2>&1 | tail -10 || echo 'WARNING: 构建或测试检查失败'",
                "timeout": 300
              }
            ],
            "description": "会话结束时验证构建通过且测试全部通过",
            "id": "stop:build-and-test-check"
          }
        ]
      }
    }
  }
}
